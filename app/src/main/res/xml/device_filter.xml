<?xml version="1.0" encoding="utf-8"?>
<!-- USB serial bridges commonly found on ESP32 Marauder boards. Vendor ids are
     decimal (Android requirement). Matching any of these makes Android offer to
     launch Marauder when the board is plugged in. -->
<resources>
    <usb-device vendor-id="4292" />   <!-- 0x10C4  Silicon Labs CP210x -->
    <usb-device vendor-id="6790" />   <!-- 0x1A86  QinHeng CH340 / CH9102 -->
    <usb-device vendor-id="1027" />   <!-- 0x0403  FTDI -->
    <usb-device vendor-id="1659" />   <!-- 0x067B  Prolific PL2303 -->
    <usb-device vendor-id="12346" />  <!-- 0x303A  Espressif native USB CDC (S2/S3/C3) -->
</resources>
